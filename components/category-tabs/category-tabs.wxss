.tabs {
  width: 100%;
  white-space: nowrap;
}

.tab-row {
  display: inline-flex;
  gap: 34rpx;
  min-width: 100%;
  padding: 0 28rpx;
}

.tab {
  position: relative;
  padding: 20rpx 0 22rpx;
  color: #6b7280;
  font-size: 30rpx;
  font-weight: 800;
}

.tab-active {
  color: #111827;
}

.tab-active::after {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 8rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: #7c3cff;
  content: "";
}
