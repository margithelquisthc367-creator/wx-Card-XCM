.tabs {
  width: 100%;
  white-space: nowrap;
}

.tab-row {
  display: inline-flex;
  gap: 28rpx;
  min-width: 100%;
  padding: 0 28rpx;
}

.tab {
  position: relative;
  padding: 18rpx 0 20rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 26rpx;
  font-weight: 700;
}

.tab-active {
  color: #fff;
}

.tab-active::after {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 8rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #7c3cff;
  content: "";
}
