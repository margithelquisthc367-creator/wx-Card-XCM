.post-card {
  display: grid;
  grid-template-columns: 1fr 188rpx;
  gap: 18rpx;
  padding: 20rpx 24rpx;
  margin: 0 20rpx 16rpx;
  border-radius: 18rpx;
  box-shadow: none;
}

.cover {
  position: relative;
  overflow: hidden;
  height: 142rpx;
  border-radius: 14rpx;
  background: #080b14;
}

.cover::before {
  position: absolute;
  inset: -30rpx;
  opacity: .9;
  content: "";
}

.cover-violet::before {
  background:
    radial-gradient(circle at 70% 32%, rgba(124, 60, 255, .78), transparent 28%),
    radial-gradient(circle at 38% 72%, rgba(31, 150, 255, .42), transparent 30%);
}

.cover-blue::before {
  background:
    radial-gradient(circle at 70% 35%, rgba(31, 150, 255, .8), transparent 28%),
    radial-gradient(circle at 30% 72%, rgba(124, 60, 255, .35), transparent 30%);
}

.cover-fan::before {
  background:
    radial-gradient(circle at 64% 28%, rgba(255, 255, 255, .2), transparent 16%),
    radial-gradient(circle at 54% 68%, rgba(124, 60, 255, .68), transparent 34%);
}

.cover-dark::before {
  background:
    radial-gradient(circle at 48% 45%, rgba(124, 60, 255, .62), transparent 33%),
    radial-gradient(circle at 78% 20%, rgba(255, 255, 255, .12), transparent 18%);
}

.cover-silver::before {
  background:
    radial-gradient(circle at 68% 32%, rgba(226, 232, 255, .58), transparent 25%),
    radial-gradient(circle at 34% 72%, rgba(31, 150, 255, .45), transparent 31%);
}

.card-spark {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  color: rgba(255, 255, 255, .8);
  font-size: 34rpx;
}

.card-fan {
  position: absolute;
  left: 74rpx;
  top: 32rpx;
  width: 100rpx;
  height: 112rpx;
}

.mini-card {
  position: absolute;
  width: 46rpx;
  height: 66rpx;
  border: 3rpx solid rgba(255, 255, 255, .86);
  border-radius: 12rpx;
  color: #111827;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 66rpx;
  text-align: center;
  background: rgba(255, 255, 255, .9);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, .28);
}

.mini-card-1 {
  left: 0;
  transform: rotate(-22deg);
}

.mini-card-2 {
  left: 28rpx;
  top: -8rpx;
  color: #7c3cff;
  transform: rotate(0deg);
}

.mini-card-3 {
  left: 56rpx;
  transform: rotate(22deg);
}

.play {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  line-height: 48rpx;
  text-align: center;
  background: rgba(0, 0, 0, .48);
  transform: translate(-50%, -50%);
  backdrop-filter: blur(8rpx);
}

.duration {
  position: absolute;
  right: 14rpx;
  bottom: 12rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 18rpx;
  background: rgba(0, 0, 0, .58);
}

.post-body {
  min-width: 0;
  padding: 0;
}

.post-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.32;
}

.post-intro {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 8rpx;
  color: #626879;
  font-size: 24rpx;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.author-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
  color: #8b8fa3;
  font-size: 22rpx;
}

.author-name {
  color: #4b5263;
  font-weight: 700;
}

.time {
  color: #a2a8b7;
}

.avatar {
  flex: none;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 34rpx;
  text-align: center;
  background: linear-gradient(135deg, #141927, #7c3cff);
}

.counts {
  display: flex;
  gap: 22rpx;
  margin-top: 12rpx;
  color: #8b8fa3;
  font-size: 22rpx;
}
