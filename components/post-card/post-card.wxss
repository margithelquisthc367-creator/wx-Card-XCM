.post-card {
  padding: 28rpx;
  margin: 0 20rpx 18rpx;
  border-radius: 20rpx;
  box-shadow: none;
}

.author-line {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  flex: none;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 92rpx;
  text-align: center;
  background: linear-gradient(135deg, #141927, #7c3cff);
}

.author-main {
  flex: 1;
  min-width: 0;
}

.author-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.author-name {
  max-width: 300rpx;
  overflow: hidden;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.level {
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 18rpx;
  font-weight: 900;
  background: #7c3cff;
}

.author-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  color: #727989;
  font-size: 24rpx;
}

.verified {
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
  color: #fff;
  background: #4b7dff;
}

.online {
  align-self: flex-start;
  flex: none;
  color: #9aa0af;
  font-size: 24rpx;
}

.post-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 34rpx;
}

.post-title {
  flex: 1;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.35;
}

.location {
  flex: none;
  color: #4b5565;
  font-size: 27rpx;
}

.post-intro {
  margin-top: 18rpx;
  color: #5f6678;
  font-size: 28rpx;
  line-height: 1.55;
}

.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 26rpx;
}

.media-item {
  position: relative;
  overflow: hidden;
  height: 188rpx;
  border-radius: 14rpx;
  background: #080b14;
}

.media-video::before,
.media-photo::before {
  position: absolute;
  inset: -30rpx;
  opacity: .95;
  content: "";
}

.cover-violet::before {
  background:
    radial-gradient(circle at 70% 32%, rgba(124, 60, 255, .78), transparent 28%),
    radial-gradient(circle at 38% 72%, rgba(31, 150, 255, .42), transparent 30%);
}

.cover-blue::before {
  background:
    radial-gradient(circle at 70% 35%, rgba(31, 150, 255, .8), transparent 28%),
    radial-gradient(circle at 30% 72%, rgba(124, 60, 255, .35), transparent 30%);
}

.cover-fan::before {
  background:
    radial-gradient(circle at 64% 28%, rgba(255, 255, 255, .2), transparent 16%),
    radial-gradient(circle at 54% 68%, rgba(124, 60, 255, .68), transparent 34%);
}

.cover-dark::before {
  background:
    radial-gradient(circle at 48% 45%, rgba(124, 60, 255, .62), transparent 33%),
    radial-gradient(circle at 78% 20%, rgba(255, 255, 255, .12), transparent 18%);
}

.cover-silver::before {
  background:
    radial-gradient(circle at 68% 32%, rgba(226, 232, 255, .58), transparent 25%),
    radial-gradient(circle at 34% 72%, rgba(31, 150, 255, .45), transparent 31%);
}

.photo-one::before {
  background:
    radial-gradient(circle at 30% 28%, rgba(255, 255, 255, .2), transparent 18%),
    linear-gradient(135deg, #172032, #2660a8 48%, #7c3cff);
}

.photo-two::before {
  background:
    radial-gradient(circle at 72% 22%, rgba(255, 255, 255, .22), transparent 16%),
    linear-gradient(135deg, #101827, #374151 46%, #1e9bff);
}

.card-spark {
  position: absolute;
  top: 20rpx;
  right: 22rpx;
  color: rgba(255, 255, 255, .8);
  font-size: 30rpx;
}

.card-fan {
  position: absolute;
  left: 44rpx;
  top: 52rpx;
  width: 108rpx;
  height: 90rpx;
}

.mini-card {
  position: absolute;
  width: 48rpx;
  height: 68rpx;
  border: 3rpx solid rgba(255, 255, 255, .86);
  border-radius: 12rpx;
  color: #111827;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 68rpx;
  text-align: center;
  background: rgba(255, 255, 255, .9);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, .28);
}

.mini-card-1 {
  left: 0;
  transform: rotate(-22deg);
}

.mini-card-2 {
  left: 30rpx;
  top: -8rpx;
  color: #7c3cff;
}

.mini-card-3 {
  left: 60rpx;
  transform: rotate(22deg);
}

.play {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  line-height: 54rpx;
  text-align: center;
  background: rgba(0, 0, 0, .48);
  transform: translate(-50%, -50%);
}

.duration {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 18rpx;
  background: rgba(0, 0, 0, .58);
}

.photo-card {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 88rpx;
  height: 118rpx;
  border: 4rpx solid rgba(255, 255, 255, .86);
  border-radius: 16rpx;
  color: #7c3cff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 118rpx;
  text-align: center;
  background: rgba(255, 255, 255, .88);
  transform: translate(-50%, -50%) rotate(-10deg);
}

.more-mask {
  position: absolute;
  right: 0;
  bottom: 0;
  min-width: 72rpx;
  height: 54rpx;
  border-top-left-radius: 14rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 54rpx;
  text-align: center;
  background: rgba(0, 0, 0, .45);
}

.post-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.counts {
  display: flex;
  flex: none;
  gap: 22rpx;
  color: #8b8fa3;
  font-size: 23rpx;
}
