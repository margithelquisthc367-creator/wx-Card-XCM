<view class="post-card card" bindtap="handleTap">
  <view class="cover cover-{{post.coverTone}}">
    <view class="card-spark">✦</view>
    <view class="card-fan">
      <view class="mini-card mini-card-1">A</view>
      <view class="mini-card mini-card-2">♠</view>
      <view class="mini-card mini-card-3">K</view>
    </view>
    <view class="play">▶</view>
    <view class="duration">{{ post.duration }}</view>
  </view>
  <view class="post-body">
    <view class="post-title">{{ post.title }}</view>
    <view class="tag-row">
      <view class="tag">{{ post.category }}</view>
      <difficulty-tag level="{{post.difficulty}}" />
    </view>
    <view class="meta-row">
      <view class="author">
        <view class="avatar">{{ post.author.avatar }}</view>
        <text>{{ post.author.nickname }}</text>
      </view>
      <view class="counts">
        <text>♡ {{ post.likes }}</text>
        <text>☷ {{ post.comments }}</text>
      </view>
    </view>
  </view>
</view>
