.work-card {
  overflow: hidden;
  border-radius: 10rpx;
  background: #fff;
}

.cover {
  position: relative;
  overflow: hidden;
  height: 360rpx;
  background: #080b14;
}

.cover::before {
  position: absolute;
  inset: -40rpx;
  content: "";
}

.cover-violet::before,
.cover-blue::before,
.cover-fan::before,
.cover-dark::before,
.cover-silver::before {
  background:
    radial-gradient(circle at 68% 24%, rgba(124, 60, 255, .76), transparent 24%),
    radial-gradient(circle at 32% 78%, rgba(31, 150, 255, .42), transparent 34%),
    linear-gradient(135deg, #07111f, #13233c);
}

.card-fan {
  position: absolute;
  left: 50%;
  top: 46%;
  width: 150rpx;
  height: 132rpx;
  transform: translate(-50%, -50%);
}

.card-fan view {
  position: absolute;
  width: 70rpx;
  height: 104rpx;
  border: 4rpx solid rgba(255, 255, 255, .86);
  border-radius: 16rpx;
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 104rpx;
  text-align: center;
  background: rgba(255, 255, 255, .92);
}

.card-fan view:nth-child(1) {
  left: 0;
  transform: rotate(-22deg);
}

.card-fan view:nth-child(2) {
  left: 42rpx;
  color: #7c3cff;
}

.card-fan view:nth-child(3) {
  left: 84rpx;
  transform: rotate(22deg);
}

.play {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 28rpx;
  line-height: 62rpx;
  text-align: center;
  background: rgba(0, 0, 0, .46);
  transform: translate(-50%, -50%);
}

.duration {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 18rpx;
  background: rgba(0, 0, 0, .5);
}

.work-body {
  padding: 22rpx 20rpx 24rpx;
}

.work-title {
  color: #202434;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.45;
}

.author-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
}

.avatar {
  flex: none;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 52rpx;
  text-align: center;
  background: linear-gradient(135deg, #141927, #7c3cff);
}

.author-main {
  flex: 1;
  min-width: 0;
}

.name {
  overflow: hidden;
  color: #3f4656;
  font-size: 23rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta,
.time {
  color: #9aa0af;
  font-size: 20rpx;
}

.time {
  flex: none;
}
