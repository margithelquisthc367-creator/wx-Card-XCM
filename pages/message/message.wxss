.message-hero {
  position: relative;
  min-height: 230rpx;
  padding-bottom: 46rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  z-index: 1;
}

.page-title {
  padding-top: 44rpx;
  color: #fff;
  font-size: 42rpx;
  font-weight: 900;
}

.entry-card {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin: -42rpx 28rpx 30rpx;
  padding: 18rpx;
}

.entry {
  text-align: center;
}

.entry-icon {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 12rpx;
  border-radius: 20rpx;
  color: #7c3cff;
  font-size: 32rpx;
  line-height: 64rpx;
  background: #f1ebff;
}

.entry-active .entry-icon {
  color: #fff;
  background: #7c3cff;
}

.entry-name {
  color: #202434;
  font-size: 24rpx;
  font-weight: 900;
}

.entry-count {
  margin-top: 6rpx;
  color: #8b8fa3;
  font-size: 20rpx;
}

.message-list {
  margin: 0 28rpx;
  padding: 8rpx 24rpx;
}

.message-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 0;
  border-top: 2rpx solid #f0f1f6;
}

.message-item:first-child {
  border-top: 0;
}

.type {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  color: #fff;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 72rpx;
  text-align: center;
  background: linear-gradient(135deg, #1e9bff, #7c3cff);
}

.message-main {
  flex: 1;
  min-width: 0;
}

.message-title {
  color: #222636;
  font-size: 27rpx;
  font-weight: 900;
}

.message-content,
.time {
  margin-top: 8rpx;
  color: #8b8fa3;
  font-size: 23rpx;
}
