.video-hero {
  min-height: 250rpx;
  padding: 0 28rpx 58rpx;
}

.topbar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  padding-top: 18rpx;
}

.back {
  color: #fff;
  font-size: 52rpx;
}

.title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
  text-align: center;
}

.subtitle {
  margin-top: 30rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 25rpx;
  text-align: center;
}

.level-panel {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 24rpx 20rpx 18rpx;
  padding: 10rpx;
  border-radius: 22rpx;
  box-shadow: none;
}

.level-tab {
  height: 64rpx;
  border-radius: 16rpx;
  color: #6b7280;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
  background: #f7f8fc;
}

.level-active {
  color: #7c3cff;
  background: #f1ebff;
}

.add-video {
  margin: 0 20rpx 18rpx;
  height: 72rpx;
  border: 2rpx dashed rgba(124, 60, 255, .42);
  border-radius: 20rpx;
  color: #7c3cff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 70rpx;
  text-align: center;
  background: #fbf9ff;
}

.video-list {
  padding: 0 20rpx;
}

.video-card {
  display: grid;
  grid-template-columns: 220rpx 1fr;
  gap: 20rpx;
  margin-bottom: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  box-shadow: none;
}

.video-cover {
  position: relative;
  overflow: hidden;
  height: 142rpx;
  border-radius: 16rpx;
  background: #080b14;
}

.video-cover::before {
  position: absolute;
  inset: -30rpx;
  content: "";
}

.cover-violet::before,
.cover-blue::before,
.cover-fan::before,
.cover-dark::before,
.cover-silver::before {
  background:
    radial-gradient(circle at 70% 32%, rgba(124, 60, 255, .72), transparent 28%),
    radial-gradient(circle at 38% 72%, rgba(31, 150, 255, .42), transparent 30%);
}

.play {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  line-height: 54rpx;
  text-align: center;
  background: rgba(0, 0, 0, .48);
  transform: translate(-50%, -50%);
}

.duration {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 18rpx;
  background: rgba(0, 0, 0, .58);
}

.video-main {
  min-width: 0;
}

.video-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.35;
}

.video-source {
  margin-top: 10rpx;
  color: #7c3cff;
  font-size: 23rpx;
  font-weight: 800;
}

.video-summary {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 10rpx;
  color: #697082;
  font-size: 24rpx;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
