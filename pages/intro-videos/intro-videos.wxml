<view class="page intro-video-page">
  <view class="video-hero dark-hero safe-top">
    <view class="topbar">
      <text class="back" bindtap="goBack">‹</text>
      <text class="title">{{category}}</text>
      <text></text>
    </view>
    <view class="subtitle">免费教学视频目录</view>
  </view>

  <view class="video-list">
    <view class="video-card card" wx:for="{{videos}}" wx:key="id" bindtap="showPreview">
      <view class="video-cover cover-{{item.coverTone}}">
        <view class="play">▶</view>
        <view class="duration">{{item.duration}}</view>
      </view>
      <view class="video-main">
        <view class="video-title">{{item.title}}</view>
        <view class="video-source">{{item.source}}</view>
        <view class="video-summary">{{item.summary}}</view>
      </view>
    </view>
  </view>

  <empty-state wx:if="{{videos.length === 0}}" title="暂无教学视频" desc="后续会继续补充免费教学目录" />
</view>
