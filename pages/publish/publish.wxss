.publish-page {
  background: #f5f6fb;
}

.publish-hero {
  position: relative;
  z-index: 1;
  min-height: 224rpx;
  padding-bottom: 22rpx;
  color: #171923;
  background: #fff;
  border-bottom: 2rpx solid #eef0f6;
}

.publish-hero.safe-top {
  padding-top: calc(92rpx + env(safe-area-inset-top));
}

.publish-hero::before {
  display: none;
}

.topbar {
  display: grid;
  grid-template-columns: 80rpx 1fr 80rpx;
  align-items: center;
  min-height: 76rpx;
  padding: 0 28rpx;
}

.back,
.more {
  color: #171923;
  font-size: 42rpx;
}

.more {
  text-align: right;
  font-size: 30rpx;
}

.title {
  color: #171923;
  font-size: 38rpx;
  font-weight: 900;
  text-align: center;
}

.form {
  position: relative;
  z-index: 2;
  margin: 24rpx 28rpx 40rpx;
  padding: 36rpx 26rpx 34rpx;
}

.field {
  margin-bottom: 36rpx;
}

.label {
  margin-bottom: 14rpx;
  color: #151923;
  font-size: 27rpx;
  font-weight: 800;
}

.label text {
  color: #ff4d68;
}

.input-wrap,
.textarea-wrap {
  position: relative;
  border: 2rpx solid #eef0f6;
  border-radius: 20rpx;
  background: #fafbff;
}

.input-wrap input {
  height: 82rpx;
  padding: 0 104rpx 0 22rpx;
  font-size: 26rpx;
}

.textarea-wrap textarea {
  width: 100%;
  height: 150rpx;
  padding: 22rpx 22rpx 48rpx;
  font-size: 26rpx;
}

.input-wrap text,
.textarea-wrap text {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  color: #9aa0af;
  font-size: 22rpx;
}

.option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option {
  min-width: 188rpx;
  height: 68rpx;
  padding: 0 20rpx;
  border: 2rpx solid #eef0f6;
  border-radius: 18rpx;
  color: #5e6475;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 66rpx;
  text-align: center;
  background: #fafbff;
}

.option-active {
  border-color: #7c3cff;
  color: #7c3cff;
  background: #f1ebff;
}

.upload-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 188rpx;
  border: 2rpx dashed #cfd4e4;
  border-radius: 24rpx;
  color: #6b7280;
  font-size: 25rpx;
  background: #fbfcff;
}

.plus {
  margin-bottom: 12rpx;
  color: #7c3cff;
  font-size: 50rpx;
  font-weight: 700;
}

.upload-tip {
  margin-top: 10rpx;
  color: #9aa0af;
  font-size: 22rpx;
}

.submit {
  width: 100%;
  height: 92rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 900;
}
