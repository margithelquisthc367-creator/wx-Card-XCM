.publish-page {
  background: linear-gradient(180deg, #05070f 0, #05070f 240rpx, #f5f6fb 240rpx);
}

.publish-hero {
  min-height: 248rpx;
}

.topbar {
  display: grid;
  grid-template-columns: 80rpx 1fr 80rpx;
  align-items: center;
  padding: 34rpx 28rpx 44rpx;
}

.back,
.more {
  color: #fff;
  font-size: 42rpx;
}

.more {
  text-align: right;
  font-size: 30rpx;
}

.title {
  color: #fff;
  font-size: 40rpx;
  font-weight: 900;
  text-align: center;
}

.form {
  margin: -72rpx 28rpx 40rpx;
  padding: 30rpx 26rpx 34rpx;
}

.field {
  margin-bottom: 30rpx;
}

.label {
  margin-bottom: 14rpx;
  color: #151923;
  font-size: 27rpx;
  font-weight: 800;
}

.label text {
  color: #ff4d68;
}

.input-wrap,
.textarea-wrap {
  position: relative;
  border: 2rpx solid #eef0f6;
  border-radius: 20rpx;
  background: #fafbff;
}

.input-wrap input {
  height: 82rpx;
  padding: 0 104rpx 0 22rpx;
  font-size: 26rpx;
}

.textarea-wrap textarea {
  width: 100%;
  height: 150rpx;
  padding: 22rpx 22rpx 48rpx;
  font-size: 26rpx;
}

.input-wrap text,
.textarea-wrap text {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  color: #9aa0af;
  font-size: 22rpx;
}

.option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option {
  min-width: 188rpx;
  height: 68rpx;
  padding: 0 20rpx;
  border: 2rpx solid #eef0f6;
  border-radius: 18rpx;
  color: #5e6475;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 66rpx;
  text-align: center;
  background: #fafbff;
}

.option-active {
  border-color: #7c3cff;
  color: #7c3cff;
  background: #f1ebff;
}

.upload-box {
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 238rpx;
  padding: 28rpx;
  border: 2rpx dashed #cfd4e4;
  border-radius: 28rpx;
  color: #6b7280;
  font-size: 25rpx;
  background: #fbfcff;
}

.upload-box-filled {
  align-items: stretch;
  justify-content: flex-start;
  border-style: solid;
  border-color: #e5e8f2;
  background: #fff;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.media-preview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.media-preview {
  position: relative;
  overflow: hidden;
  height: 164rpx;
  border-radius: 20rpx;
  background: #080b14;
}

.video-badge,
.first-badge {
  position: absolute;
  z-index: 2;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 19rpx;
}

.video-badge {
  left: 10rpx;
  bottom: 10rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(0, 0, 0, .56);
}

.first-badge {
  left: 10rpx;
  top: 10rpx;
  font-weight: 800;
  background: rgba(124, 60, 255, .86);
}

.remove-media {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  z-index: 3;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 30rpx;
  line-height: 32rpx;
  text-align: center;
  background: rgba(0, 0, 0, .52);
}

.upload-title {
  color: #3f4554;
  font-size: 27rpx;
  font-weight: 800;
}

.upload-desc,
.upload-tip {
  margin-top: 12rpx;
  color: #9aa0af;
  font-size: 23rpx;
  line-height: 1.5;
  text-align: center;
}

.upload-tip {
  margin-top: 18rpx;
}

.publish-error {
  margin: -12rpx 0 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  color: #991b1b;
  font-size: 23rpx;
  line-height: 1.6;
  word-break: break-all;
  background: #fee2e2;
}

.plus {
  margin-bottom: 12rpx;
  color: #7c3cff;
  font-size: 50rpx;
  font-weight: 700;
}

.submit {
  width: 100%;
  height: 92rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 900;
}
