<view class="page publish-page">
  <view class="publish-hero dark-hero safe-top">
    <view class="topbar">
      <text class="back">‹</text>
      <text class="title">创作</text>
      <text class="more">•••</text>
    </view>
  </view>

  <view class="form card">
    <view class="field">
      <view class="label">标题 <text>*</text></view>
      <view class="input-wrap">
        <input value="{{form.title}}" maxlength="30" placeholder="请输入作品标题（最多30字）" bindinput="updateTitle" />
        <text>{{form.title.length}}/30</text>
      </view>
    </view>

    <view class="field">
      <view class="label">简介 <text>*</text></view>
      <view class="textarea-wrap">
        <textarea value="{{form.intro}}" maxlength="200" placeholder="介绍你的动作亮点、创意或技巧要点..." bindinput="updateIntro" />
        <text>{{form.intro.length}}/200</text>
      </view>
    </view>

    <view class="field">
      <view class="label">分类 <text>*</text></view>
      <view class="option-grid">
        <view
          wx:for="{{publishCategories}}"
          wx:key="*this"
          class="option {{form.category === item ? 'option-active' : ''}}"
          data-value="{{item}}"
          bindtap="chooseCategory"
        >
          {{ item }}
        </view>
      </view>
    </view>

    <view class="field">
      <view class="label">上传 <text>*</text></view>
      <view class="upload-box {{mediaFiles.length ? 'upload-box-filled' : ''}}" bindtap="chooseMedia">
        <block wx:if="{{mediaFiles.length}}">
          <view class="media-preview-grid">
            <view wx:for="{{mediaFiles}}" wx:key="path" class="media-preview">
              <video
                wx:if="{{item.type === 'video'}}"
                class="upload-preview"
                src="{{item.path}}"
                controls="{{false}}"
                show-center-play-btn="{{true}}"
                object-fit="cover"
              />
              <image wx:else class="upload-preview" src="{{item.path}}" mode="aspectFill" />
              <view class="video-badge" wx:if="{{item.type === 'video'}}">
                <text>▶</text>
                <text>{{item.duration}}</text>
              </view>
              <view class="first-badge" wx:if="{{index === 0}}">
                {{item.type === 'video' ? '帖子第1张' : '首图'}}
              </view>
              <view class="remove-media" data-index="{{index}}" catchtap="removeMedia">×</view>
            </view>
          </view>
          <view class="upload-tip">点击可重新选择，视频会显示在帖子第一张</view>
        </block>
        <block wx:else>
          <text class="plus">+</text>
          <text class="upload-title">上传照片/视频</text>
          <text class="upload-desc">可只发图片，也可选择视频；有视频时自动放在帖子第一张</text>
        </block>
      </view>
    </view>

    <view class="publish-error" wx:if="{{errorText}}">{{errorText}}</view>

    <button class="submit primary-gradient" loading="{{submitting}}" bindtap="submit">发布我的创作</button>
  </view>
</view>
