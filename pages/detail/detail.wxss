.detail-page {
  padding-bottom: 128rpx;
  background: #f5f6fb;
}

.video {
  position: relative;
  overflow: hidden;
  height: 520rpx;
  background: #05070f;
}

.video::before {
  position: absolute;
  inset: -50rpx;
  content: "";
}

.cover-violet::before,
.cover-blue::before,
.cover-fan::before,
.cover-dark::before,
.cover-silver::before {
  background:
    radial-gradient(circle at 66% 32%, rgba(124, 60, 255, .78), transparent 27%),
    radial-gradient(circle at 40% 70%, rgba(31, 150, 255, .42), transparent 31%);
}

.back {
  position: absolute;
  left: 26rpx;
  top: calc(44rpx + env(safe-area-inset-top));
  z-index: 3;
  width: 60rpx;
  height: 60rpx;
  color: #fff;
  font-size: 54rpx;
  line-height: 54rpx;
}

.detail-cards {
  position: absolute;
  left: 190rpx;
  top: 150rpx;
  width: 320rpx;
  height: 190rpx;
}

.detail-cards view {
  position: absolute;
  width: 120rpx;
  height: 168rpx;
  border: 4rpx solid rgba(255, 255, 255, .9);
  border-radius: 18rpx;
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 168rpx;
  text-align: center;
  background: rgba(255, 255, 255, .92);
}

.detail-cards view:nth-child(1) {
  left: 10rpx;
  transform: rotate(-24deg);
}

.detail-cards view:nth-child(2) {
  left: 96rpx;
  color: #7c3cff;
  transform: rotate(0);
}

.detail-cards view:nth-child(3) {
  left: 182rpx;
  transform: rotate(24deg);
}

.play {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 42rpx;
  line-height: 96rpx;
  text-align: center;
  background: rgba(0, 0, 0, .5);
  transform: translate(-50%, -50%);
}

.progress {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #fff;
  font-size: 22rpx;
}

.bar {
  flex: 1;
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .32);
}

.bar view {
  width: 36%;
  height: 100%;
  border-radius: inherit;
  background: #7c3cff;
}

.detail-card {
  margin: 18rpx 0 24rpx;
  padding: 34rpx 28rpx 30rpx;
  border-top-left-radius: 34rpx;
  border-top-right-radius: 34rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.detail-title {
  flex: 1;
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
}

.date {
  align-self: flex-end;
  color: #a0a5b4;
  font-size: 22rpx;
}

.tag-row {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.author-row {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
}

.avatar,
.comment-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 70rpx;
  text-align: center;
  background: linear-gradient(135deg, #111827, #7c3cff);
}

.author-main {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.name {
  color: #222636;
  font-size: 28rpx;
  font-weight: 900;
}

.level {
  margin-left: 10rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 18rpx;
  font-weight: 800;
  background: #7c3cff;
}

.bio {
  display: block;
  margin-top: 6rpx;
  color: #8b8fa3;
  font-size: 23rpx;
}

.follow {
  width: 96rpx;
  height: 54rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 54rpx;
  background: #7c3cff;
}

.intro {
  margin-top: 28rpx;
  color: #3b4050;
  font-size: 27rpx;
  line-height: 1.7;
}

.topic {
  margin-top: 14rpx;
  color: #7c3cff;
  font-size: 25rpx;
  font-weight: 700;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 34rpx;
  border-top: 2rpx solid #f0f1f6;
}

.action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding-top: 24rpx;
  color: #6d7284;
  font-size: 23rpx;
}

.action text:first-child {
  color: #222636;
  font-size: 44rpx;
}

.action.active,
.action.active text:first-child {
  color: #7c3cff;
}

.comments {
  margin: 0 28rpx;
  padding: 28rpx;
}

.section-title {
  margin-bottom: 20rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.comment {
  display: flex;
  gap: 16rpx;
  padding: 22rpx 0;
  border-top: 2rpx solid #f3f4f8;
}

.comment:first-of-type {
  border-top: 0;
}

.comment-main {
  flex: 1;
  min-width: 0;
}

.comment-name {
  color: #232838;
  font-size: 25rpx;
  font-weight: 800;
}

.comment-content {
  margin-top: 8rpx;
  color: #4a5060;
  font-size: 25rpx;
  line-height: 1.5;
}

.comment-meta,
.comment-like {
  margin-top: 8rpx;
  color: #a0a5b4;
  font-size: 22rpx;
}

.comment-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, .94);
  backdrop-filter: blur(16rpx);
}

.comment-bar input {
  flex: 1;
  height: 70rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f2f3f8;
}

.comment-bar button {
  width: 104rpx;
  height: 70rpx;
  border-radius: 22rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 70rpx;
  background: #7c3cff;
}
