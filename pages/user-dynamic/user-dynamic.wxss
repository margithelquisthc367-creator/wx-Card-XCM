.creator-page {
  background: #f5f6fb;
}

.creator-cover {
  position: relative;
  overflow: hidden;
  height: 300rpx;
  color: #fff;
  background:
    radial-gradient(circle at 78% 20%, rgba(124, 60, 255, .52), transparent 28%),
    radial-gradient(circle at 18% 10%, rgba(31, 150, 255, .36), transparent 24%),
    linear-gradient(145deg, #05070f, #0a1020 58%, #11172a);
}

.creator-cover::after {
  position: absolute;
  right: 46rpx;
  bottom: 30rpx;
  color: rgba(255, 255, 255, .12);
  font-size: 126rpx;
  content: "♠";
}

.cover-glow {
  position: absolute;
  left: -80rpx;
  bottom: -80rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(31, 150, 255, .18);
  filter: blur(8rpx);
}

.topbar {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.back {
  color: #fff;
  font-size: 52rpx;
}

.title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
  text-align: center;
}

.more {
  color: rgba(255, 255, 255, .86);
  font-size: 28rpx;
  text-align: right;
}

.creator-profile {
  position: relative;
  z-index: 3;
  margin: -74rpx 24rpx 22rpx;
  padding: 26rpx 24rpx 24rpx;
  border-radius: 30rpx;
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.big-avatar {
  flex: none;
  width: 132rpx;
  height: 132rpx;
  border: 6rpx solid #fff;
  border-radius: 50%;
  color: #fff;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 120rpx;
  text-align: center;
  background: linear-gradient(135deg, #141927, #7c3cff);
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, .18);
}

.identity {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nickname {
  overflow: hidden;
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.level {
  flex: none;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  color: #fff;
  font-size: 19rpx;
  font-weight: 900;
  background: #7c3cff;
}

.bio {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.follow-btn {
  flex: none;
  width: 146rpx;
  height: 62rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 62rpx;
  background: linear-gradient(135deg, #7c3cff, #9b5cff);
  box-shadow: 0 12rpx 24rpx rgba(124, 60, 255, .24);
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #eef0f6;
}

.stat-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-item:not(:last-child)::after {
  position: absolute;
  right: 0;
  top: 10rpx;
  width: 1rpx;
  height: 56rpx;
  background: #eef0f6;
  content: "";
}

.stat-item text:first-child {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.stat-item text:last-child {
  color: #8b8fa3;
  font-size: 22rpx;
  font-weight: 700;
}

.creator-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin: 0 24rpx 22rpx;
  padding: 8rpx;
  border-radius: 24rpx;
}

.creator-tab {
  height: 64rpx;
  border-radius: 18rpx;
  color: #7b8191;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
}

.creator-tab.active {
  color: #7c3cff;
  background: #f1ebff;
}

.creator-intro {
  margin: 0 24rpx 26rpx;
  padding: 24rpx;
  border-radius: 26rpx;
}

.intro-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
}

.intro-text {
  margin-top: 12rpx;
  color: #5f6678;
  font-size: 25rpx;
  line-height: 1.55;
}

.intro-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.intro-tags text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #7c3cff;
  font-size: 22rpx;
  background: #f1ebff;
}

.section-head {
  display: flex;
  justify-content: space-between;
  padding: 0 28rpx 18rpx;
}

.section-head text:first-child {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.section-head text:last-child {
  color: #8b8fa3;
  font-size: 24rpx;
}
