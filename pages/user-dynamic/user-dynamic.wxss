.user-hero {
  position: relative;
  min-height: 330rpx;
  padding: 0 28rpx 48rpx;
}

.topbar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  padding-top: 18rpx;
}

.back {
  color: #fff;
  font-size: 52rpx;
}

.title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
  text-align: center;
}

.user-row {
  display: flex;
  align-items: center;
  margin-top: 52rpx;
}

.big-avatar {
  width: 128rpx;
  height: 128rpx;
  border: 6rpx solid rgba(255, 255, 255, .84);
  border-radius: 50%;
  color: #fff;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 116rpx;
  text-align: center;
  background: linear-gradient(135deg, #141927, #7c3cff);
}

.user-main {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.nickname {
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
}

.level {
  margin-left: 12rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  background: #7c3cff;
}

.bio {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .78);
  font-size: 24rpx;
  line-height: 1.5;
}

.activity-card {
  margin: -34rpx 20rpx 28rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  box-shadow: none;
}

.activity-title {
  color: #1f2433;
  font-size: 29rpx;
  font-weight: 900;
}

.activity-item {
  margin-top: 16rpx;
  color: #5f6678;
  font-size: 24rpx;
  line-height: 1.5;
}

.section-head {
  display: flex;
  justify-content: space-between;
  padding: 0 28rpx 18rpx;
}

.section-head text:first-child {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.section-head text:last-child {
  color: #8b8fa3;
  font-size: 24rpx;
}
