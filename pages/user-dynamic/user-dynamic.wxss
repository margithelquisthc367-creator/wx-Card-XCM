.user-hero {
  position: relative;
  min-height: 330rpx;
  padding: 0 28rpx 48rpx;
}

.topbar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  padding-top: 18rpx;
}

.back {
  color: #fff;
  font-size: 52rpx;
}

.title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
  text-align: center;
}

.user-row {
  display: flex;
  align-items: center;
  margin-top: 52rpx;
}

.big-avatar {
  width: 128rpx;
  height: 128rpx;
  border: 6rpx solid rgba(255, 255, 255, .84);
  border-radius: 50%;
  color: #fff;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 116rpx;
  text-align: center;
  background: linear-gradient(135deg, #141927, #7c3cff);
}

.user-main {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.nickname {
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
}

.level {
  margin-left: 12rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  background: #7c3cff;
}

.bio {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .78);
  font-size: 24rpx;
  line-height: 1.5;
}

.creator-card {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin: -28rpx 28rpx 42rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 42rpx rgba(18, 24, 42, .08);
}

.creator-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 118rpx;
  border-radius: 18rpx;
  background: #fafbff;
}

.creator-stat text:first-child {
  color: #111827;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.creator-stat text:last-child {
  color: #8a91a3;
  font-size: 22rpx;
  font-weight: 700;
}

.section-head {
  display: flex;
  justify-content: space-between;
  padding: 0 28rpx 18rpx;
}

.section-head text:first-child {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.section-head text:last-child {
  color: #8b8fa3;
  font-size: 24rpx;
}
