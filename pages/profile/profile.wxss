.profile-hero {
  position: relative;
  min-height: 360rpx;
  padding-bottom: 54rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  z-index: 1;
}

.hero-deco {
  position: absolute;
  right: 42rpx;
  top: 106rpx;
  color: rgba(168, 131, 255, .58);
  font-size: 30rpx;
}

.user-row {
  position: relative;
  display: flex;
  align-items: center;
  padding-top: 78rpx;
}

.big-avatar {
  width: 140rpx;
  height: 140rpx;
  border: 6rpx solid rgba(255, 255, 255, .84);
  border-radius: 50%;
  color: #fff;
  font-size: 62rpx;
  font-weight: 900;
  line-height: 128rpx;
  text-align: center;
  background: linear-gradient(135deg, #141927, #7c3cff);
}

.user-main {
  flex: 1;
  min-width: 0;
  margin-left: 26rpx;
}

.nickname {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
}

.level {
  margin-left: 12rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  background: #7c3cff;
}

.bio,
.location {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .78);
  font-size: 24rpx;
  line-height: 1.5;
}

.stats {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin: -24rpx 28rpx 36rpx;
  padding: 30rpx 8rpx;
  border: 1rpx solid rgba(231, 235, 245, .96);
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, .08);
}

.stats view {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stats view:not(:last-child)::after {
  position: absolute;
  top: 10rpx;
  right: 0;
  width: 1rpx;
  height: 58rpx;
  background: #edf0f7;
  content: "";
}

.stats text:first-child {
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
}

.stats text:last-child {
  color: #777d8f;
  font-size: 23rpx;
}

.section {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  padding: 0 30rpx 18rpx;
}

.section-head text:first-child {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.section-head text:last-child {
  color: #8b8fa3;
  font-size: 24rpx;
}

.profile-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin: 0 20rpx 18rpx;
  padding: 8rpx;
  border-radius: 18rpx;
  box-shadow: none;
}

.profile-tab {
  height: 62rpx;
  border-radius: 14rpx;
  color: #747b8c;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 62rpx;
  text-align: center;
}

.profile-tab-active {
  color: #7c3cff;
  background: #f1ebff;
}
