<view class="page intro-page">
  <view class="intro-hero dark-hero safe-top">
    <view class="topbar">
      <text class="back" bindtap="goBack">‹</text>
      <text class="title">入门XCM</text>
      <text></text>
    </view>
    <view class="subtitle">基础花切与魔术流程目录</view>
  </view>

  <view class="directory card">
    <view
      wx:for="{{tabs}}"
      wx:key="*this"
      class="directory-item"
      data-value="{{item}}"
      bindtap="openDirectory"
    >
      <text>{{item === '花切新手' ? '＋' : '♠'}}</text>
      <view class="directory-main">
        <view>{{item}}</view>
        <view>免费教学视频目录</view>
      </view>
    </view>
  </view>
</view>
