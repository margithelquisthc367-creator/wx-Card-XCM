.intro-hero {
  min-height: 330rpx;
  padding: calc(96rpx + env(safe-area-inset-top)) 28rpx 54rpx;
}

.topbar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
}

.back {
  position: absolute;
  left: 0;
  top: 50%;
  color: #fff;
  font-size: 52rpx;
  line-height: 72rpx;
  transform: translateY(-50%);
}

.title {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 72rpx;
  text-align: center;
}

.subtitle {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 25rpx;
  text-align: center;
}

.directory {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin: 24rpx 24rpx 34rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 16rpx 42rpx rgba(18, 24, 42, .08);
}

.directory-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 128rpx;
  padding: 0 28rpx;
  border: 2rpx solid #eef0f6;
  border-radius: 24rpx;
  color: #3f4554;
  font-size: 27rpx;
  font-weight: 900;
  background: #fafbff;
}

.directory-item text {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  color: #7c3cff;
  line-height: 48rpx;
  text-align: center;
  background: #f1ebff;
}

.directory-item:active {
  border-color: rgba(124, 60, 255, .6);
  color: #7c3cff;
  background: #f6f2ff;
  box-shadow: inset 0 0 0 1rpx rgba(124, 60, 255, .08);
}

.directory-main view:first-child {
  color: #3f4554;
  font-size: 29rpx;
  font-weight: 900;
}

.directory-main view:last-child {
  margin-top: 8rpx;
  color: #8b8fa3;
  font-size: 23rpx;
}
