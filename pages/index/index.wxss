.index-hero {
  padding-bottom: 8rpx;
  border-bottom-left-radius: 34rpx;
  border-bottom-right-radius: 34rpx;
}

.hero-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  padding: 12rpx 28rpx 24rpx;
}

.brand {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 0;
  text-transform: capitalize;
}

.spade {
  color: #a883ff;
  font-size: 36rpx;
}

.search-box {
  display: flex;
  align-items: center;
  height: 74rpx;
  margin: 0 28rpx 12rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  color: rgba(255, 255, 255, .56);
  background: rgba(255, 255, 255, .1);
}

.search-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.search-placeholder {
  font-size: 26rpx;
}

.feed {
  padding-top: 26rpx;
}
