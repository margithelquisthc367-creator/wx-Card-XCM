.show-hero {
  min-height: 250rpx;
  padding: 0 28rpx 44rpx;
}

.topbar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  padding-top: 18rpx;
}

.back {
  color: #fff;
  font-size: 52rpx;
}

.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
  text-align: center;
}

.subtitle {
  margin-top: 30rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 25rpx;
  text-align: center;
}

.feed-title {
  padding: 28rpx 24rpx 18rpx;
  color: #1f2433;
  font-size: 30rpx;
  font-weight: 900;
}
